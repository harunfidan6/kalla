PORT=4000
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Public HTTPS URL of this backend — iyzico's callback and the mock payment page both
# redirect here. Must be a real reachable HTTPS URL (Android WebView blocks cleartext http
# and phones can't resolve "localhost" to the server at all).
API_BASE_URL=http://localhost:4000
